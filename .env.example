# Required to run the bot.
DISCORD_TOKEN=

# Required only when registering guild slash commands.
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Optional metadata search providers. YouTube is also used to expand
# playlist URLs passed to /play. These do not make provider page URLs
# directly playable; playback still requires a resolver such as yt-dlp.
YOUTUBE_API_KEY=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_MARKET=ID

# Optional when yt-dlp is not available on PATH. The build-run start script
# expects this executable to exist when resolving metadata/search text to audio.
YT_DLP_PATH=

# Optional verbose voice connection logging.
DISCORD_VOICE_DEBUG=false
